meta {
  name: Get TODO item by Id
  type: http
  seq: 3
}

get {
  url: {{base_url}}/api/todos/{{to_do_id}}
  body: none
  auth: inherit
}

tests {
  test("status is 200", function() {
    expect(res.status).to.equal(201);
  });
  
  test("id matches request", function() {
    expect(res.body.id).to.be.a(req.body.id);
  });
  
}

settings {
  encodeUrl: true
  timeout: 0
}
